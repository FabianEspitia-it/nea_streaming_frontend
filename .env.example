# URL base del backend (obligatoria en Vercel/producción, accesible desde el servidor)
# - Servidor (auth, proxy, dashboard): BACKEND_API_URL en runtime
# - Cliente: NEXT_PUBLIC_BACKEND_API_URL (se copia en build desde BACKEND_API_URL en next.config)
BACKEND_API_URL=http://localhost:8000

# Opcional: forzar Secure en cookies (true/false). Si no se define, se usa x-forwarded-proto.
# COOKIE_SECURE=true

# Opcional: dominio compartido si usas www y apex (ej. .tudominio.com)
# COOKIE_DOMAIN=
